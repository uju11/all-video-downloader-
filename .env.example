# Cloudflare R2 Configuration (for 10GB free storage)
# Set USE_R2 to true to enable Cloudflare R2 storage
USE_R2=true

# R2 Bucket Configuration
R2_BUCKET=video-downloads

# R2 API Credentials (get these from Cloudflare Dashboard)
# Go to: R2 > Manage R2 API Tokens > Create API Token
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key_id
R2_SECRET_KEY=your_secret_access_key

# Local Storage Configuration (fallback if USE_R2=false)
# When USE_R2=false, files are stored locally in /app/downloads
# Note: Local storage has 100MB limit for Render, 1GB for persistent disk
